# App Store Connect API key — generate at:
# https://appstoreconnect.apple.com/access/integrations/api
# Role: App Manager (sufficient for metadata + screenshots; do NOT use Admin)
#
# Copy this file to fastlane/.env and fill in your values. fastlane/.env is gitignored.

ASC_KEY_ID=ABCD123456
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=./fastlane/AuthKey_ABCD123456.p8

# Apple ID for the developer account (used by Appfile)
APPLE_ID=you@example.com

# App Store Connect numeric team id (different from the Apple Developer Team ID `TAC8TU62HY`)
# Find at: App Store Connect → top-right user menu → your team name → numeric id in URL
ITC_TEAM_ID=123456789
