    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This app uses your location to provide accurate prayer times and reminders based on your\n      current location. Your location data will be used while you are using the app and may also be\n      used in the background to send you notifications about upcoming prayers. Your location data\n      will not be shared with any third parties."
          }
        }
      }
    },
    "NSLocationAlwaysUsageDescription" : {
      "comment" : "Privacy - Location Always Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This app uses your location to provide accurate prayer times and reminders based on your\n      current location. Your location data will be used only for this purpose and will not be shared\n      with any third parties."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Nedaa uses your precise location while you use the app to calculate the Qibla direction and provide accurate prayer times and reminders. Your location is not shared with third parties."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم نداء موقعك الدقيق أثناء استخدام التطبيق لحساب اتجاه القبلة وتقديم أوقات صلاة وتذكيرات دقيقة. لا تتم مشاركة موقعك مع أي طرف ثالث."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
