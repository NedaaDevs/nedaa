    "nextPrayerLockScreenWidgetDesc": {
      "comment": "Lock screen widget description",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعرض وقت الصلاة القادمة. يظهر مؤقت العد التنازلي 60 دقيقة قبل الصلاة. ويبدأ العد 30 دقيقة بعد الصلاة"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Displays the next prayer. it shows a countdown timer 60 minutes before the prayer. And count up 30 minutes after"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memaparkan solat seterusnya. Ia menunjukkan pemasa kira detik 60 minit sebelum solat, dan mengira menaik 30 minit selepasnya"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگلی نماز ظاہر ہوتی ہے۔ نماز سے 60 منٹ پہلے الٹی گنتی اور نماز کے 30 منٹ بعد سیدھی گنتی دکھائی جاتی ہے۔"
          }
        }
      }
    },
