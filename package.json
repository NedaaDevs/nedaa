{
  "name": "nedaa",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write",
    "prepare": "husky",
    "clean:cache": "./scripts/clean-cache.sh",
    "clean:derived": "./scripts/clean-derived.sh",
    "clean:pods": "./scripts/clean-pods.sh",
    "clean:all": "./scripts/clean-all.sh",
    "reinstall:ios": "./scripts/reinstall-ios.sh",
    "nuke": "./scripts/nuke.sh",
    "build:android": "bun scripts/build-local.ts android production",
    "build:android:hms": "bun scripts/build-local.ts android production-hms",
    "build:ios": "bun scripts/build-local.ts ios production",
    "submit:android:closed": "eas submit -p android --latest --profile closed-testing",
    "submit:android:internal": "eas submit -p android --latest --profile internal",
    "submit:android:production": "eas submit -p android --latest --profile production",
    "release:android:closed": "bun run build:android && bun run submit:android:closed",
    "release:android:internal": "bun run build:android && bun run submit:android:internal",
    "release:android:production": "bun run build:android && bun run submit:android:production",
    "screenshots:verify": "cd scripts/screenshots && PATH=\"$HOME/.maestro/bin:$PATH\" bun run.ts verify",
    "eas-build-pre-install": "[ \"$BUILD_VARIANT\" = \"hms\" ] && [ -n \"$AGCONNECT_SERVICES_JSON\" ] && cp \"$AGCONNECT_SERVICES_JSON\" android/app/agconnect-services.json || true"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/scripts/"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/asap": "^0.4.3",
    "@expo-google-fonts/ibm-plex-sans-arabic": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "7.15.2",
    "@react-navigation/native": "7.1.31",
    "@react-navigation/native-stack": "7.14.2",
    "@tamagui/animations-moti": "2.1.0",
    "@tamagui/config": "2.1.0",
    "@tamagui/linear-gradient": "2.1.0",
    "@tamagui/native": "2.1.0",
    "axios": "^1.16.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "expo": "^57.0.0",
    "expo-alarm": "file:./modules/expo-alarm",
    "expo-application": "~57.0.0",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.0",
    "expo-background-task": "~57.0.2",
    "expo-build-properties": "~57.0.3",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-custom-notification-sound": "file:./modules/expo-custom-notification-sound",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-location": "~57.0.2",
    "expo-mail-composer": "~57.0.0",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-orientation": "file:./modules/expo-orientation",
    "expo-router": "~57.0.3",
    "expo-sharing": "~57.0.2",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-task-manager": "~57.0.2",
    "expo-web-browser": "~57.0.0",
    "expo-widgets": "file:./modules/expo-widgets",
    "hijri-native": "0.1.2",
    "i18next": "^26.3.0",
    "intl-pluralrules": "^2.0.1",
    "lucide-react-native": "^1.17.0",
    "miftah": "^1.1.5",
    "moti": "^0.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-color-matrix-image-filters": "^8.0.2",
    "react-native-email-link": "^1.16.1",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-nitro-player": "^1.4.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-worklets": "0.10.0",
    "react-native-zip-archive": "^8.0.1",
    "tamagui": "2.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "2.1.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "baseline-browser-mapping": "^2.10.33",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "expo-dev-client": "~57.0.5",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "lint-staged": "^17.0.6",
    "metro-minify-terser": "^0.83.6",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 1",
      "bun run lint"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "overrides": {
    "@react-navigation/native": "7.1.31",
    "@react-navigation/bottom-tabs": "7.15.2",
    "@react-navigation/native-stack": "7.14.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo-widgets"
      ]
    }
  }
}
